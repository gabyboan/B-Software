---
import Layout from "../layouts/Layout.astro";

const title = "Sobre B-Software y Gabriel Boan | Desarrollo de software";
const description =
  "Conocé el enfoque de B-Software, la marca profesional de Gabriel Boan para desarrollar sistemas internos, aplicaciones Flutter e integraciones orientadas a procesos reales.";
const canonical = "https://bsoftware.pages.dev/sobre-b-software/";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfilePage",
      "@id": `${canonical}#profile-page`,
      url: canonical,
      name: title,
      description,
      inLanguage: "es-AR",
      mainEntity: { "@id": `${canonical}#gabriel-boan` },
      isPartOf: { "@id": "https://bsoftware.pages.dev/#website" },
    },
    {
      "@type": "Person",
      "@id": `${canonical}#gabriel-boan`,
      name: "Gabriel Boan",
      url: canonical,
      email: "mailto:gabrielboan14@gmail.com",
      homeLocation: {
        "@type": "Place",
        name: "Paraná, Entre Ríos, Argentina",
      },
      worksFor: {
        "@type": "Organization",
        "@id": "https://bsoftware.pages.dev/#organization",
        name: "B-Software",
      },
      sameAs: ["https://github.com/gabyboan"],
      knowsAbout: [
        "Desarrollo Flutter",
        "Sistemas internos",
        "Supabase",
        "PostgreSQL",
        "Seguridad de datos",
        "Cloudflare",
        "QA funcional",
      ],
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Inicio", item: "https://bsoftware.pages.dev/" },
        { "@type": "ListItem", position: 2, name: "Sobre B-Software", item: canonical },
      ],
    },
  ],
};

const principles = [
  {
    title: "Entender antes de automatizar",
    text: "Una herramienta tiene sentido cuando representa bien el proceso, sus excepciones y las personas que la van a usar.",
  },
  {
    title: "Explicar las decisiones",
    text: "El alcance, las reglas y los límites técnicos deben poder conversarse sin esconderse detrás de complejidad innecesaria.",
  },
  {
    title: "Construir para sostener",
    text: "Datos consistentes, permisos, pruebas y documentación importan porque el producto continúa después de la primera entrega.",
  },
];
---

<Layout {title} {description} {canonical} ogType="profile" navVariant="compact">
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main class="about-page">
    <header class="about-hero">
      <a class="back-link" href="/">← Volver al inicio</a>
      <p class="eyebrow">Sobre B-Software</p>
      <h1>Software con criterio operativo, no solamente pantallas.</h1>
      <div class="about-intro">
        <p>
          B-Software es la marca profesional independiente de <strong>Gabriel Boan</strong>, desarrollador de Paraná, Entre Ríos.
        </p>
        <p>
          El trabajo se concentra en sistemas internos, aplicaciones Flutter e integraciones donde hay procesos, permisos y datos que necesitan ordenarse.
        </p>
      </div>
    </header>

    <section class="about-facts" aria-label="Información principal">
      <div><span>Base</span><strong>Paraná · Entre Ríos</strong></div>
      <div><span>Modalidad</span><strong>Proyectos locales y remotos</strong></div>
      <div><span>Especialidad</span><strong>Software operativo</strong></div>
      <div><span>Respaldo</span><strong>Código y casos públicos</strong></div>
    </section>

    <section class="about-section story-section">
      <div>
        <p class="section-label">01 / Enfoque</p>
        <h2>Resolver el recorrido completo.</h2>
      </div>
      <div class="story-copy">
        <p>
          Un sistema interno no es únicamente una colección de formularios. Detrás hay identidades, estados, validaciones, excepciones y decisiones que deben conservar contexto.
        </p>
        <p>
          Por eso el trabajo empieza entendiendo cómo circula la información. La tecnología se elige después: Flutter para una experiencia multiplataforma, Supabase y PostgreSQL para reglas y datos, o Cloudflare para portales y servicios en el borde cuando el producto lo necesita.
        </p>
        <p>
          El objetivo es que cada entrega sea útil para quien opera el producto y comprensible para quien debe mantenerlo o hacerlo crecer.
        </p>
      </div>
    </section>

    <section class="principles-section" aria-labelledby="principles-title">
      <div class="principles-heading">
        <p class="section-label">02 / Principios</p>
        <h2 id="principles-title">Una forma concreta de trabajar.</h2>
      </div>
      <div class="principles-list">
        {principles.map((principle, index) => (
          <article><span>{String(index + 1).padStart(2, "0")}</span><div><h3>{principle.title}</h3><p>{principle.text}</p></div></article>
        ))}
      </div>
    </section>

    <section class="about-section evidence-section">
      <div>
        <p class="section-label">03 / Evidencia</p>
        <h2>Los casos cuentan mejor el trabajo.</h2>
      </div>
      <div class="evidence-links">
        <a href="/proyectos/gestion-recursos-humanos/">
          <span>Gestión de Recursos Humanos</span>
          <small>Aplicaciones conectadas, roles y núcleo compartido</small>
          <strong aria-hidden="true">↗</strong>
        </a>
        <a href="/proyectos/comparador-geolocalizado-de-precios/">
          <span>Comparador geolocalizado de precios</span>
          <small>Flutter, ubicación y clasificación de fuentes</small>
          <strong aria-hidden="true">↗</strong>
        </a>
        <a href="/proyectos/nido-inmobiliaria/">
          <span>Nido Inmobiliaria · Beta técnica</span>
          <small>Flutter, catálogo y validación multiplataforma</small>
          <strong aria-hidden="true">↗</strong>
        </a>
        <a href="https://github.com/gabyboan" target="_blank" rel="noreferrer">
          <span>GitHub</span>
          <small>Repositorios y documentación técnica pública</small>
          <strong aria-hidden="true">↗</strong>
        </a>
      </div>
    </section>

    <section class="about-contact">
      <div><p class="section-label">Contacto directo</p><h2>¿Hay un proceso que necesita orden?</h2></div>
      <div class="about-actions">
        <a class="button primary" href="mailto:gabrielboan14@gmail.com">gabrielboan14@gmail.com</a>
        <a class="button secondary" href="https://wa.me/5493434064408" target="_blank" rel="noreferrer">WhatsApp</a>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <a class="footer-brand" href="/" aria-label="B-Software inicio">
        <span class="footer-logo"><img src="/brand/logo-b.png" alt="" width="64" height="64" loading="lazy" /></span>
        <span><strong>B Software</strong><small>Sistemas internos, Flutter e integraciones</small></span>
      </a>
      <nav class="footer-links" aria-label="Enlaces secundarios">
        <a href="/#proyectos">Casos</a><a href="/#servicios">Servicios</a><a href="/#contacto">Contacto</a>
      </nav>
    </div>
  </footer>
</Layout>

<style>
  .about-page { background: #f5f4f0; color: #171815; }
  .about-hero, .about-facts, .about-section, .about-contact { max-width: 1180px; margin: 0 auto; padding-inline: 20px; }
  .about-hero { padding-top: 64px; padding-bottom: 76px; }
  .about-hero h1 { max-width: 1050px; font-size: clamp(3.4rem, 7.2vw, 7.4rem); line-height: .92; letter-spacing: -.06em; }
  .about-intro { margin-top: 54px; margin-left: auto; max-width: 730px; display: grid; grid-template-columns: 1fr 1fr; gap: 34px; color: #61645e; font-size: 1.05rem; line-height: 1.8; }
  .about-intro strong { color: #171815; }
  .about-facts { display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid #cbc9c2; border-bottom: 1px solid #cbc9c2; }
  .about-facts div { padding: 20px 18px 20px 0; }.about-facts div + div { border-left: 1px solid #cbc9c2; padding-left: 18px; }
  .about-facts span, .about-facts strong { display: block; }.about-facts span, .section-label { color: #263fbd; font-size: .7rem; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; }.about-facts strong { margin-top: 8px; font-size: .9rem; }
  .about-section { padding-top: 104px; padding-bottom: 104px; display: grid; grid-template-columns: .82fr 1.18fr; gap: 90px; }
  .about-section h2, .principles-heading h2, .about-contact h2 { font-size: clamp(2.4rem, 4.8vw, 4.7rem); letter-spacing: -.045em; }
  .story-copy { display: grid; gap: 24px; padding-top: 26px; color: #61645e; font-size: 1.07rem; line-height: 1.85; }
  .principles-section { padding: 100px max(20px, calc((100vw - 1140px) / 2)); display: grid; grid-template-columns: .82fr 1.18fr; gap: 90px; color: #f5f4f0; background: #111214; }
  .principles-section .section-label { color: #a89bf7; }.principles-list article { display: grid; grid-template-columns: 48px 1fr; gap: 20px; border-top: 1px solid rgb(255 255 255 / .18); padding: 26px 0; }.principles-list article:last-child { border-bottom: 1px solid rgb(255 255 255 / .18); }.principles-list article > span { color: #a89bf7; font-size: .72rem; font-weight: 900; }.principles-list h3 { font-size: 1.25rem; }.principles-list p { margin-top: 9px; color: rgb(255 255 255 / .65); line-height: 1.75; }
  .evidence-section { border-bottom: 1px solid #cbc9c2; }.evidence-links { border-top: 1px solid #cbc9c2; }.evidence-links a { min-height: 112px; display: grid; grid-template-columns: 1fr 1fr auto; gap: 24px; align-items: center; border-bottom: 1px solid #cbc9c2; }.evidence-links span { font-weight: 900; }.evidence-links small { color: #6b6e68; }.evidence-links strong { color: #263fbd; font-size: 1.4rem; }.evidence-links a:hover span { text-decoration: underline; text-underline-offset: 5px; }
  .about-contact { padding-top: 86px; padding-bottom: 86px; display: grid; grid-template-columns: 1fr auto; gap: 50px; align-items: end; }.about-actions { display: grid; gap: 10px; }
  @media (max-width: 900px) {
    .about-intro, .about-section, .principles-section, .about-contact { grid-template-columns: 1fr; }.about-intro { margin-left: 0; }.about-facts { grid-template-columns: 1fr 1fr; }.about-facts div:nth-child(3) { border-left: 0; border-top: 1px solid #cbc9c2; }.about-facts div:nth-child(4) { border-top: 1px solid #cbc9c2; }.about-section, .principles-section { gap: 46px; }.evidence-links a { grid-template-columns: 1fr auto; }.evidence-links small { grid-column: 1; }.evidence-links strong { grid-row: 1 / 3; grid-column: 2; }
  }
  @media (max-width: 540px) {
    .about-hero, .about-facts, .about-section, .about-contact { padding-inline: 14px; }.about-hero h1 { font-size: clamp(3rem, 15vw, 4.2rem); }.about-intro { grid-template-columns: 1fr; }.about-facts { grid-template-columns: 1fr; }.about-facts div + div, .about-facts div:nth-child(3) { border-left: 0; border-top: 1px solid #cbc9c2; padding-left: 0; }.principles-section { padding-inline: 14px; }.about-actions .button { width: 100%; }
  }
</style>
