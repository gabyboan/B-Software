---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    title: "Legajo Digital",
    type: "Sistema interno",
    problem:
      "La información operativa de cada legajo necesitaba una consulta centralizada y controlada.",
    solution:
      "Panel web para administrar situación de revista, carrera, asistencia y banco inicial de horas.",
    stack: ["Next.js", "React", "TypeScript", "Supabase"],
    result:
      "Flujos administrativos reunidos en una interfaz con autenticación, roles y datos estructurados.",
    href: "https://github.com/gabyboan/legajo-digital",
    cta: "Ver arquitectura",
  },
  {
    title: "HESM Gestión RRHH",
    type: "Aplicación de escritorio",
    problem:
      "El registro de horas, francos y novedades requería reducir tareas manuales y facilitar la exportación.",
    solution:
      "Sistema operativo Flutter para registrar, consultar y exportar información de trabajo.",
    stack: ["Flutter", "Dart", "Riverpod", "Supabase"],
    result:
      "Una herramienta de escritorio orientada a la carga diaria y a consultas operativas consistentes.",
    href: "https://github.com/gabyboan/hesm-gestion-rrhh",
    cta: "Ver arquitectura",
  },
  {
    title: "Consulta Horas",
    type: "Portal público",
    problem:
      "Publicar consultas conectadas a datos internos requería controlar abuso y limitar la superficie expuesta.",
    solution:
      "Portal público con validación anti-abuso, Worker intermedio y acceso acotado mediante Supabase.",
    stack: ["Cloudflare Pages", "Workers", "Turnstile", "Supabase"],
    result:
      "Consulta web separada del sistema interno, con despliegue edge y controles específicos de acceso.",
    href: "https://github.com/gabyboan/consulta-horas",
    cta: "Ver arquitectura",
  },
  {
    title: "Suplencias Propuesta",
    type: "Aplicación operativa",
    problem:
      "La carga y consulta de propuestas necesitaba roles claros y prevención de registros duplicados.",
    solution:
      "Aplicación Flutter con autenticación, permisos y validaciones conectadas a PostgreSQL.",
    stack: ["Flutter", "Dart", "Supabase", "PostgreSQL"],
    result:
      "Base funcional para ordenar el circuito de propuestas y aplicar reglas desde la capa de datos.",
    href: "https://github.com/gabyboan/app-suplencias-propuesta",
    cta: "Ver arquitectura",
  },
];

const services = [
  {
    title: "Sistemas internos y paneles operativos",
    description:
      "Herramientas con roles, flujos, auditoría y datos centralizados para ordenar la operación diaria.",
  },
  {
    title: "Aplicaciones Flutter",
    description:
      "Aplicaciones móviles y de escritorio con una base compartida, interfaces claras e integración con servicios reales.",
  },
  {
    title: "Supabase, PostgreSQL y seguridad",
    description:
      "Modelado de datos, RLS, RPCs, autenticación y revisión de permisos para reducir superficies expuestas.",
  },
  {
    title: "Automatizaciones e integraciones",
    description:
      "Conexión entre sistemas, APIs, notificaciones y procesos repetitivos con trazabilidad técnica.",
  },
  {
    title: "QA técnico y despliegue",
    description:
      "Pruebas funcionales, smoke testing, revisión de errores y publicación en infraestructura adecuada.",
  },
  {
    title: "Sitios y portales públicos",
    description:
      "Webs rápidas y accesibles, portales de consulta, SEO técnico y despliegues modernos en Cloudflare.",
  },
];

const offers = [
  {
    title: "Sistema interno a medida",
    description:
      "Paneles, roles, base de datos, auditoría de acciones y flujos definidos para la operación diaria.",
  },
  {
    title: "Aplicación Flutter",
    description:
      "Producto móvil o de escritorio conectado a APIs, autenticación y una base de datos segura.",
  },
  {
    title: "Integración y automatización",
    description:
      "Procesos conectados, alertas, importaciones y tareas repetitivas convertidas en flujos controlables.",
  },
  {
    title: "QA y auditoría técnica",
    description:
      "Pruebas, revisión de accesos, diagnóstico de errores y recomendaciones con alcance definido.",
  },
];

const quality = [
  {
    value: "QA",
    label: "Pruebas funcionales, smoke testing, regresión y escenarios críticos antes de publicar.",
  },
  {
    value: "DATA",
    label: "Modelos de datos, migraciones y consultas pensadas para consistencia y trazabilidad.",
  },
  {
    value: "SEC",
    label: "Revisión de roles, permisos, RLS, RPCs y superficies expuestas.",
  },
  {
    value: "OPS",
    label: "Logs, despliegue, documentación y lectura de fallos para sostener la operación.",
  },
];

const workSteps = [
  "Relevamiento y validación técnica.",
  "Prototipo o primera entrega funcional.",
  "Desarrollo por hitos con alcance definido.",
  "Entrega, documentación y soporte acordado.",
];

const faqs = [
  {
    question: "¿Qué tipo de productos desarrolla B-Software?",
    answer:
      "Sistemas internos, aplicaciones Flutter, portales públicos, automatizaciones, integraciones y herramientas para equipos operativos.",
  },
  {
    question: "¿Cómo se define el alcance?",
    answer:
      "Cada etapa comienza con objetivos, entregables y criterios de validación acordados antes de iniciar el bloque de trabajo.",
  },
  {
    question: "¿Se realizan pruebas antes de publicar?",
    answer:
      "Sí. El alcance puede incluir pruebas funcionales, smoke testing, escenarios críticos, revisión de errores y validación previa al despliegue.",
  },
  {
    question: "¿También ofrecen soporte y redes?",
    answer:
      "Sí, como servicio complementario. El foco principal de B-Software está en desarrollo, integraciones, calidad y operación de productos digitales.",
  },
];

const brandPieces = [
  {
    src: "/brand/servicio-pc-lenta.png",
    alt: "Pieza gráfica de soporte técnico para equipos",
    title: "Soporte técnico",
  },
  {
    src: "/brand/asesoramiento-componentes.png",
    alt: "Pieza gráfica de asesoramiento en componentes",
    title: "Asesoramiento",
  },
  {
    src: "/brand/redes-wifi.png",
    alt: "Pieza gráfica de configuración de redes WiFi",
    title: "Redes y conectividad",
  },
];

const profiles = [
  {
    name: "GitHub",
    href: "https://github.com/gabyboan",
    label: "Código y documentación pública como respaldo técnico",
  },
  {
    name: "Email",
    href: "mailto:gabrielboan14@gmail.com",
    label: "Contacto directo para consultas y presupuestos",
  },
  {
    name: "WhatsApp",
    href: "https://wa.me/5493434064408",
    label: "Canal de contacto comercial existente",
  },
];

const professionalServiceStructuredData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "B-Software",
  url: "https://bsoftware.pages.dev/",
  logo: "https://bsoftware.pages.dev/brand/logo-b.png",
  image: "https://bsoftware.pages.dev/b-software-hero.png",
  email: "gabrielboan14@gmail.com",
  telephone: "+54 9 343 406 4408",
  areaServed: ["Argentina", "Entre Ríos", "Paraná", "Remote"],
  description:
    "Desarrollo de sistemas internos, aplicaciones Flutter, automatizaciones e integraciones con Supabase y PostgreSQL, seguridad, QA y despliegue.",
  sameAs: ["https://github.com/gabyboan"],
  knowsAbout: [
    "Desarrollo Flutter",
    "Sistemas internos",
    "Software empresarial",
    "Aplicaciones móviles",
    "Automatizaciones",
    "Supabase",
    "PostgreSQL",
    "Row Level Security",
    "Integraciones",
    "Cloudflare",
    "QA técnico",
  ],
  makesOffer: offers.map((offer) => ({
    "@type": "Offer",
    itemOffered: {
      "@type": "Service",
      name: offer.title,
      description: offer.description,
    },
  })),
};

const websiteStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "B-Software",
  alternateName: "B Software",
  url: "https://bsoftware.pages.dev/",
  inLanguage: "es-AR",
  description:
    "Sistemas internos, desarrollo Flutter, Supabase, PostgreSQL, automatizaciones, integraciones y QA técnico.",
  publisher: {
    "@type": "Organization",
    name: "B-Software",
    url: "https://bsoftware.pages.dev/",
    logo: "https://bsoftware.pages.dev/brand/logo-b.png",
  },
};

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify(professionalServiceStructuredData)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />

  <main>
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Desarrollo a medida para operación real</p>
        <h1>Software operativo para negocios y equipos que necesitan ordenar procesos</h1>
        <p class="hero-lead">
          Desarrollo sistemas internos, aplicaciones móviles, automatizaciones e integraciones con foco en seguridad, trazabilidad y operación real.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="#proyectos">Ver proyectos</a>
          <a class="button secondary" href="#contacto">Solicitar presupuesto</a>
        </div>
      </div>
      <div class="hero-media">
        <img class="hero-logo" src="/brand/logo-b.png" alt="Logo B-Software" width="1120" height="1120" />
        <div class="hero-panel">
          <p>Sistemas internos y Flutter</p>
          <p>Supabase, PostgreSQL y seguridad</p>
          <p>Integraciones, QA y despliegue</p>
        </div>
      </div>
    </section>

    <section class="section intro-band" aria-label="Enfoque de trabajo">
      <div>
        <span class="metric">Datos</span>
        <p>permisos, trazabilidad y reglas cerca de la fuente</p>
      </div>
      <div>
        <span class="metric">Hitos</span>
        <p>alcance y entregables definidos por etapa</p>
      </div>
      <div>
        <span class="metric">QA</span>
        <p>validación técnica antes de cada publicación</p>
      </div>
    </section>

    <section id="servicios" class="section">
      <div class="section-heading">
        <p class="eyebrow">Servicios principales</p>
        <h2>Software a medida, desde la operación hasta el despliegue</h2>
        <p class="section-lead">
          El trabajo se concentra en productos que conectan procesos, personas y datos sin perder control técnico.
        </p>
      </div>
      <div class="service-card-grid">
        {services.map((service, index) => (
          <article class="service-card">
            <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section case-preview">
      <div class="case-preview-copy">
        <p class="eyebrow">Caso de estudio destacado</p>
        <p class="project-type">Proyecto de investigación y demostración técnica</p>
        <h2>Comparador geolocalizado de precios</h2>
        <p class="case-lead">
          Aplicación mobile-first para comparar productos, precios, sucursales y nivel de certeza de cada fuente.
        </p>
        <ul class="check-list">
          <li>Búsqueda, comparación, favoritos y lista estimada.</li>
          <li>Geolocalización y sucursales cercanas.</li>
          <li>Flutter, Supabase, RPCs seguras, RLS y pipeline NDJSON.</li>
          <li>Clasificación de precios según evidencia y alcance local.</li>
        </ul>
        <a class="button primary" href="/proyectos/comparador-geolocalizado-de-precios/">
          Ver caso de estudio
        </a>
      </div>
      <div class="case-visual" aria-label="Esquema conceptual del comparador de precios">
        <div class="case-phone">
          <span class="case-phone-bar"></span>
          <div class="case-search">Buscar producto</div>
          <div class="case-product">
            <span></span>
            <div><strong>Producto comparable</strong><small>3 fuentes evaluadas</small></div>
          </div>
          <div class="certainty-row"><span>Local verificable</span><strong>Alta certeza</strong></div>
          <div class="certainty-row"><span>Precio online</span><strong>Referencia</strong></div>
          <div class="certainty-row"><span>Precio observado</span><strong>Con fecha</strong></div>
        </div>
      </div>
    </section>

    <section id="proyectos" class="section">
      <div class="section-heading">
        <p class="eyebrow">Portfolio</p>
        <h2>Problemas concretos, soluciones explicables</h2>
        <p class="section-lead">
          Cada tarjeta resume el valor del proyecto. GitHub queda como respaldo técnico cuando existe documentación pública.
        </p>
      </div>
      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card">
            <p class="project-type">{project.type}</p>
            <h3>{project.title}</h3>
            <dl class="project-details">
              <div>
                <dt>Problema</dt>
                <dd>{project.problem}</dd>
              </div>
              <div>
                <dt>Solución</dt>
                <dd>{project.solution}</dd>
              </div>
              <div>
                <dt>Resultado</dt>
                <dd>{project.result}</dd>
              </div>
            </dl>
            <div class="stack-list">
              {project.stack.map((item) => <span>{item}</span>)}
            </div>
            <a href={project.href} target={project.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
              {project.cta}
            </a>
          </article>
        ))}
      </div>
    </section>

    <section id="metodo" class="section work-section">
      <div class="section-heading">
        <p class="eyebrow">Cómo trabajo</p>
        <h2>Un proceso por etapas, con decisiones visibles</h2>
      </div>
      <ol class="work-grid">
        {workSteps.map((step, index) => (
          <li>
            <span>{index + 1}</span>
            <p>{step}</p>
          </li>
        ))}
      </ol>
      <p class="commercial-note">
        Los proyectos se trabajan por etapas, con alcance y entregables definidos antes de iniciar cada bloque.
      </p>
    </section>

    <section id="calidad" class="section quality-section">
      <div class="section-heading">
        <p class="eyebrow">Criterio técnico</p>
        <h2>Calidad, seguridad y operación desde la arquitectura</h2>
      </div>
      <div class="quality-grid">
        {quality.map((item) => (
          <article class="quality-card">
            <span>{item.value}</span>
            <p>{item.label}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section offers-section">
      <div class="section-heading">
        <p class="eyebrow">Puntos de partida</p>
        <h2>Servicios listos para definir y presupuestar</h2>
      </div>
      <div class="offers-grid">
        {offers.map((offer) => (
          <article class="offer-card">
            <h3>{offer.title}</h3>
            <p>{offer.description}</p>
            <a href="#contacto">Solicitar presupuesto</a>
          </article>
        ))}
      </div>
    </section>

    <section id="github" class="section github-section">
      <div class="github-copy">
        <p class="eyebrow">Respaldo técnico</p>
        <h2>Código público donde aporta contexto</h2>
        <p>
          Los repositorios disponibles complementan el portfolio con documentación y decisiones de arquitectura. Los casos se explican primero por su problema, solución y resultado.
        </p>
        <a class="button github-button" href="https://github.com/gabyboan" target="_blank" rel="noreferrer">
          Ver GitHub
        </a>
      </div>
      <div class="github-list">
        <div><span>APP</span><p>Aplicaciones Flutter y herramientas orientadas a procesos operativos.</p></div>
        <div><span>DATA</span><p>Supabase, PostgreSQL, autenticación, roles y reglas de acceso.</p></div>
        <div><span>WEB</span><p>Astro, Cloudflare Pages, Workers, portales públicos y despliegue.</p></div>
      </div>
    </section>

    <section class="section brand-section secondary-services">
      <div class="section-heading">
        <p class="eyebrow">Servicios complementarios</p>
        <h2>Soporte, asesoramiento y conectividad</h2>
        <p class="section-lead">
          Estas capacidades acompañan proyectos cuando el contexto lo requiere, sin desplazar el foco principal en software.
        </p>
      </div>
      <div class="brand-grid">
        {brandPieces.map((piece) => (
          <article class="brand-card">
            <img src={piece.src} alt={piece.alt} width="1080" height="1080" loading="lazy" />
            <h3>{piece.title}</h3>
          </article>
        ))}
      </div>
    </section>

    <section class="section discover-section">
      <div class="section-heading">
        <p class="eyebrow">Contacto y referencia</p>
        <h2>Conversación comercial, evidencia técnica y canales directos</h2>
      </div>
      <div class="profile-grid">
        {profiles.map((profile) => (
          <a href={profile.href} target={profile.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
            <strong>{profile.name}</strong>
            <span>{profile.label}</span>
          </a>
        ))}
      </div>
    </section>

    <section id="faq" class="section faq-section">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2>Preguntas frecuentes</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section id="contacto" class="contact-section">
      <div>
        <p class="eyebrow">Contacto</p>
        <h2>Conversemos sobre el próximo bloque de trabajo</h2>
        <p>
          Podés solicitar presupuesto para un sistema interno, una aplicación Flutter, una integración, un portal público o una revisión técnica.
        </p>
      </div>
      <div class="contact-actions">
        <a class="button primary" href="mailto:gabrielboan14@gmail.com">gabrielboan14@gmail.com</a>
        <a class="button secondary" href="https://wa.me/5493434064408" target="_blank" rel="noreferrer">WhatsApp 343 406-4408</a>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <a class="footer-brand" href="/" aria-label="B-Software inicio">
        <span class="footer-logo">
          <img src="/brand/logo-b.png" alt="" width="64" height="64" loading="lazy" />
        </span>
        <span>
          <strong>B Software</strong>
          <small>Sistemas internos, Flutter e integraciones</small>
        </span>
      </a>
      <nav class="footer-links" aria-label="Enlaces secundarios">
        <a href="/#servicios">Servicios</a>
        <a href="/#proyectos">Proyectos</a>
        <a href="/#faq">FAQ</a>
        <a href="/#contacto">Contacto</a>
      </nav>
    </div>
  </footer>
</Layout>
