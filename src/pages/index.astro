---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    title: "Legajo Digital",
    type: "Sistema interno",
    description:
      "Panel para consultar y administrar legajos, situacion de revista, carrera, asistencia y banco inicial de horas.",
    stack: ["Next.js", "React", "TypeScript", "Supabase"],
    href: "https://github.com/gabyboan/legajo-digital",
  },
  {
    title: "HESM Gestion RRHH",
    type: "Aplicacion de escritorio",
    description:
      "Sistema operativo para registrar, consultar y exportar horas, francos y novedades de recursos humanos.",
    stack: ["Flutter", "Dart", "Riverpod", "Supabase"],
    href: "https://github.com/gabyboan/hesm-gestion-rrhh",
  },
  {
    title: "Consulta Horas",
    type: "Portal publico",
    description:
      "Consulta publica de horas con despliegue moderno, proteccion anti-abuso y datos conectados a Supabase.",
    stack: ["Cloudflare Pages", "Workers", "Turnstile", "Supabase"],
    href: "https://github.com/gabyboan/consulta-horas",
  },
];

const services = [
  "Aplicaciones web empresariales a medida",
  "Productos digitales con metricas y trazabilidad",
  "Testing funcional, smoke testing y pruebas ad hoc",
  "Observabilidad, monitoreo y analisis de errores",
  "Hardening, revision de vulnerabilidades y control de acceso",
  "Integracion con Supabase, PostgreSQL y Cloudflare",
];

const offers = [
  {
    title: "Sistema interno a medida",
    description: "Paneles, roles, base de datos, auditoria de acciones y flujos hechos para la operacion diaria.",
  },
  {
    title: "Web institucional profesional",
    description: "Sitios rapidos, claros y listos para vender con SEO tecnico, OG Graph y despliegue en Cloudflare.",
  },
  {
    title: "QA y auditoria tecnica",
    description: "Smoke testing, pruebas ad hoc, revision de errores, vulnerabilidades y recomendaciones accionables.",
  },
  {
    title: "Mantenimiento mensual",
    description: "Monitoreo, cambios evolutivos, soporte, mejoras de performance y acompanamiento tecnico.",
  },
];

const automations = [
  {
    title: "WhatsApp",
    tag: "Atencion y respuestas",
    description:
      "Flujos para consultas frecuentes, derivacion de contactos, avisos operativos y respuestas guiadas para equipos comerciales o administrativos.",
    className: "whatsapp",
  },
  {
    title: "Telegram",
    tag: "Alertas y operaciones",
    description:
      "Bots y notificaciones para seguimiento interno, avisos tecnicos, estados de sistemas, reportes y comandos rapidos para equipos de trabajo.",
    className: "telegram",
  },
];

const githubTour = [
  "Repositorios publicos para mostrar criterio tecnico y capacidad de entrega.",
  "Proyectos con stack moderno: Next.js, Flutter, Astro, Supabase, PostgreSQL, Cloudflare y Workers.",
  "Codigo orientado a productos reales: autenticacion, roles, formularios, paneles, escritorio, despliegues y documentacion.",
];

const faqs = [
  {
    question: "Que tipo de productos puede desarrollar B-Software?",
    answer:
      "Sistemas internos, webs institucionales, portales publicos, automatizaciones, integraciones con base de datos y herramientas para equipos operativos.",
  },
  {
    question: "Se entregan pruebas antes de publicar?",
    answer:
      "Si. Se trabaja con pruebas funcionales, smoke testing, escenarios ad hoc, revision de errores y validacion de flujos criticos antes del despliegue.",
  },
  {
    question: "Pueden automatizar WhatsApp o Telegram?",
    answer:
      "Si. Se pueden crear flujos de atencion, bots, alertas, respuestas guiadas, reportes y derivaciones para mejorar la operacion diaria.",
  },
  {
    question: "Tambien hacen mantenimiento y soporte?",
    answer:
      "Si. Se puede contratar mantenimiento mensual, monitoreo, correcciones, mejoras evolutivas, soporte tecnico y acompanamiento de infraestructura.",
  },
];

const quality = [
  {
    value: "QA",
    label: "Pruebas funcionales, smoke testing, regresion y escenarios ad hoc antes de entregar.",
  },
  {
    value: "OBS",
    label: "Metricas, logs, monitoreo y lectura de fallos para operar productos reales.",
  },
  {
    value: "SEC",
    label: "Revision de vulnerabilidades, roles, permisos y superficies expuestas.",
  },
  {
    value: "Cisco",
    label: "Formacion y certificaciones Cisco aplicadas a redes, infraestructura y soporte.",
  },
];

const brandPieces = [
  {
    src: "/brand/servicio-pc-lenta.png",
    alt: "Pieza grafica de soporte para PC lenta e internet",
    title: "Soporte tecnico",
  },
  {
    src: "/brand/asesoramiento-componentes.png",
    alt: "Pieza grafica de asesoramiento personalizado para componentes",
    title: "Asesoramiento",
  },
  {
    src: "/brand/redes-wifi.png",
    alt: "Pieza grafica de configuracion de WiFi y routers",
    title: "Redes y conectividad",
  },
];

const profiles = [
  {
    name: "GitHub",
    href: "https://github.com/gabyboan",
    label: "Codigo, repositorios y proyectos publicados",
  },
  {
    name: "Email",
    href: "mailto:gabrielboan14@gmail.com",
    label: "Contacto directo para presupuestos y soporte",
  },
  {
    name: "WhatsApp",
    href: "https://wa.me/5493434064408",
    label: "Consultas comerciales y seguimiento de proyectos",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "B-Software",
  url: "https://bsoftware.pages.dev/",
  logo: "https://bsoftware.pages.dev/brand/logo-b.png",
  image: "https://bsoftware.pages.dev/b-software-hero.png",
  email: "gabrielboan14@gmail.com",
  telephone: "+54 9 343 406 4408",
  areaServed: ["Argentina", "Entre Rios", "Parana", "Remote"],
  description:
    "Desarrollo de software empresarial, aplicaciones web, QA, observabilidad, seguridad, testing y soporte tecnico.",
  sameAs: ["https://github.com/gabyboan"],
  knowsAbout: [
    "Software empresarial",
    "Aplicaciones web",
    "Testing funcional",
    "Smoke testing",
    "Observabilidad",
    "Metricas",
    "Revision de vulnerabilidades",
    "Supabase",
    "PostgreSQL",
    "Cloudflare",
    "Cisco",
    "Automatizaciones WhatsApp",
    "Bots Telegram",
  ],
  makesOffer: offers.map((offer) => ({
    "@type": "Offer",
    itemOffered: {
      "@type": "Service",
      name: offer.title,
      description: offer.description,
    },
  })),
};

const organizationStructuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "B-Software",
  alternateName: "B Software",
  url: "https://bsoftware.pages.dev/",
  logo: "https://bsoftware.pages.dev/brand/logo-b.png",
  image: "https://bsoftware.pages.dev/b-software-hero.png",
  email: "gabrielboan14@gmail.com",
  telephone: "+54 9 343 406 4408",
  sameAs: ["https://github.com/gabyboan"],
  founder: {
    "@type": "Person",
    name: "Gabriel Boan",
    email: "gabrielboan14@gmail.com",
    url: "https://github.com/gabyboan",
  },
};

const websiteStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "B-Software",
  alternateName: "B Software",
  url: "https://bsoftware.pages.dev/",
  inLanguage: "es-AR",
  description:
    "Sitio oficial de B-Software: desarrollo web, software empresarial, automatizaciones, QA tecnico, observabilidad y soporte.",
  publisher: {
    "@type": "Organization",
    name: "B-Software",
  },
};

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <script type="application/ld+json" set:html={JSON.stringify(organizationStructuredData)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  <main>
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Software empresarial con calidad de entrega</p>
        <h1>B-Software</h1>
        <p class="hero-lead">
          Construimos productos digitales serios: sistemas web, paneles internos, portales publicos e integraciones listas para operar con metricas, observabilidad, testing y seguridad desde el primer despliegue.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="#contacto">Contacte con nosotros</a>
          <a class="button secondary" href="#calidad">Ver calidad</a>
        </div>
      </div>
      <div class="hero-media">
        <img class="hero-logo" src="/brand/logo-b.png" alt="Logo B-Software" width="1120" height="1120" />
        <div class="hero-panel">
          <p>Testing y control de errores</p>
          <p>Metricas y observabilidad</p>
          <p>Seguridad y buenas practicas</p>
        </div>
      </div>
    </section>

    <section class="section intro-band" aria-label="Resumen">
      <div>
        <span class="metric">4+</span>
        <p>productos institucionales y operativos desarrollados</p>
      </div>
      <div>
        <span class="metric">24/7</span>
        <p>deploys, monitoreo y disponibilidad pensados para uso real</p>
      </div>
      <div>
        <span class="metric">QA</span>
        <p>pruebas de humo, escenarios ad hoc y validacion antes de publicar</p>
      </div>
    </section>

    <section id="calidad" class="section quality-section">
      <div class="section-heading">
        <p class="eyebrow">Calidad de producto</p>
        <h2>Software medible, probado y preparado para crecer</h2>
      </div>
      <div class="quality-grid">
        {quality.map((item) => (
          <article class="quality-card">
            <span>{item.value}</span>
            <p>{item.label}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="automatizaciones" class="section automation-section">
      <div class="section-heading">
        <p class="eyebrow">Automatizaciones</p>
        <h2>Canales que trabajan junto al negocio</h2>
      </div>
      <div class="automation-grid">
        {automations.map((item) => (
          <article class:list={["automation-card", item.className]}>
            <div class="automation-icon" aria-hidden="true">
              {item.title === "WhatsApp" ? (
                <svg viewBox="0 0 24 24" role="img">
                  <path d="M12 3.2a8.6 8.6 0 0 0-7.4 13l-.9 4.1 4.2-1a8.6 8.6 0 1 0 4.1-16.1Zm0 1.8a6.8 6.8 0 1 1-3.5 12.6l-.3-.2-2.2.5.5-2.1-.2-.4A6.8 6.8 0 0 1 12 5Zm-2.5 3.5c-.2 0-.5.1-.7.4-.3.3-.8.8-.8 1.9 0 1.1.8 2.2.9 2.3.1.2 1.6 2.7 4 3.6 2 .8 2.4.5 2.9.5.4 0 1.4-.6 1.6-1.1.2-.6.2-1 .1-1.1-.1-.1-.2-.2-.5-.3l-1.6-.8c-.2-.1-.4-.1-.6.2l-.7.8c-.1.2-.3.2-.5.1-.3-.1-1.1-.4-2-1.2-.8-.7-1.3-1.6-1.4-1.8-.2-.3 0-.4.1-.5l.4-.5c.1-.2.2-.3.3-.5.1-.2.1-.3 0-.5l-.7-1.7c-.2-.5-.4-.5-.6-.5h-.2Z" />
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" role="img">
                  <path d="M20.8 4.1 3.8 10.7c-1.1.4-1.1 1.1-.2 1.4l4.4 1.4 1.7 5.2c.2.6.4.8.8.8.4 0 .6-.2.9-.5l2.1-2.1 4.4 3.2c.8.4 1.3.2 1.5-.8L22 5.5c.3-1.2-.5-1.7-1.2-1.4Zm-2.2 3.2-8.5 7.6-.3 3.1-1.4-4.7 10.2-6Z" />
                </svg>
              )}
            </div>
            <p class="automation-tag">{item.tag}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="proyectos" class="section">
      <div class="section-heading">
        <p class="eyebrow">Portfolio</p>
        <h2>Proyectos realizados</h2>
      </div>

      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card">
            <p class="project-type">{project.type}</p>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <div class="stack-list">
              {project.stack.map((item) => <span>{item}</span>)}
            </div>
            <a href={project.href} target={project.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
              Ver detalle
            </a>
          </article>
        ))}
      </div>
    </section>

    <section id="github" class="section github-section">
      <div class="github-copy">
        <p class="eyebrow">Paseo por GitHub</p>
        <h2>Codigo, repositorios y evidencia tecnica</h2>
        <p>
          El perfil de GitHub permite ver proyectos publicados, decisiones de stack y avances reales. Es una vidriera tecnica para evaluar forma de trabajo, documentacion y capacidad de despliegue.
        </p>
        <a class="button github-button" href="https://github.com/gabyboan" target="_blank" rel="noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 0 1.6 1.1 1.6 1.1.9 1.5 2.4 1.1 3 .8.1-.7.4-1.1.7-1.4-2.3-.3-4.7-1.2-4.7-5a3.9 3.9 0 0 1 1-2.7 3.6 3.6 0 0 1 .1-2.7s.9-.3 2.8 1a9.7 9.7 0 0 1 5 0c1.9-1.3 2.8-1 2.8-1a3.6 3.6 0 0 1 .1 2.7 3.9 3.9 0 0 1 1 2.7c0 3.9-2.4 4.8-4.7 5 .4.3.7.9.7 1.8V21c0 .3.2.6.8.5A10 10 0 0 0 12 2Z" />
          </svg>
          Ver GitHub
        </a>
      </div>
      <div class="github-list">
        {githubTour.map((item) => (
          <div>
            <span aria-hidden="true">GH</span>
            <p>{item}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="servicios" class="section split-section">
      <div class="section-heading">
        <p class="eyebrow">Que vendemos</p>
        <h2>Productos digitales de calidad para empresas y equipos</h2>
      </div>
      <div class="service-list">
        {services.map((service) => (
          <div class="service-item">
            <span aria-hidden="true">+</span>
            <p>{service}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section offers-section">
      <div class="section-heading">
        <p class="eyebrow">Paquetes</p>
        <h2>Servicios listos para presupuestar</h2>
      </div>
      <div class="offers-grid">
        {offers.map((offer) => (
          <article class="offer-card">
            <h3>{offer.title}</h3>
            <p>{offer.description}</p>
            <a href="#contacto">Pedir presupuesto</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section brand-section">
      <div class="section-heading">
        <p class="eyebrow">Identidad</p>
        <h2>Marca y contenido visual</h2>
      </div>
      <div class="brand-grid">
        {brandPieces.map((piece) => (
          <article class="brand-card">
            <img src={piece.src} alt={piece.alt} width="1080" height="1080" loading="lazy" />
            <h3>{piece.title}</h3>
          </article>
        ))}
      </div>
    </section>

    <section class="section discover-section">
      <div class="section-heading">
        <p class="eyebrow">Presencia profesional</p>
        <h2>Preparado para compartir en Google, LinkedIn, GitHub y plataformas freelance</h2>
        <p>
          La pagina publica de B-Software incluye contenido descriptivo, Open Graph, sitemap, robots.txt, llms.txt y datos estructurados para que buscadores, asistentes de IA y redes profesionales comprendan que servicios ofrece la marca.
        </p>
      </div>
      <div class="profile-grid">
        {profiles.map((profile) => (
          <a href={profile.href} target={profile.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
            <strong>{profile.name}</strong>
            <span>{profile.label}</span>
          </a>
        ))}
      </div>
    </section>

    <section id="faq" class="section faq-section">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2>Preguntas frecuentes</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section id="contacto" class="contact-section">
      <div>
        <p class="eyebrow">Contacto</p>
        <h2>Contacte con nosotros</h2>
        <p>
          Contacte con nosotros para presupuestar sistemas internos, automatizaciones, portales publicos, soporte tecnico, revisiones de calidad o despliegues con observabilidad.
        </p>
      </div>
      <div class="contact-actions">
        <a class="button primary" href="mailto:gabrielboan14@gmail.com">gabrielboan14@gmail.com</a>
        <a class="button secondary" href="https://wa.me/5493434064408" target="_blank" rel="noreferrer">WhatsApp 343 406-4408</a>
      </div>
    </section>
  </main>
  <footer class="site-footer">
    <div class="footer-inner">
      <a class="footer-brand" href="/" aria-label="B-Software inicio">
        <span class="footer-logo">
          <img src="/brand/logo-b.png" alt="" width="64" height="64" loading="lazy" />
        </span>
        <span>
          <strong>B Software</strong>
          <small>Desarrollo web, sistemas internos y automatizaciones</small>
        </span>
      </a>

      <nav class="footer-links" aria-label="Enlaces secundarios">
        <a href="#servicios">Servicios</a>
        <a href="#proyectos">Proyectos</a>
        <a href="#faq">FAQ</a>
        <a href="#contacto">Contacto</a>
      </nav>
    </div>
  </footer>
</Layout>
