---
import Layout from "../layouts/Layout.astro";

const services = [
  {
    number: "01",
    title: "Sistemas internos",
    description:
      "Paneles y herramientas para centralizar información, aplicar roles y reemplazar tareas dispersas por flujos controlables.",
    detail: "Procesos · permisos · trazabilidad",
  },
  {
    number: "02",
    title: "Aplicaciones Flutter",
    description:
      "Productos móviles y de escritorio conectados a servicios reales, con interfaces pensadas para la operación cotidiana.",
    detail: "Mobile · escritorio · APIs",
  },
  {
    number: "03",
    title: "Integraciones y automatización",
    description:
      "Conexión entre sistemas, portales y datos para reducir pasos manuales sin perder validaciones ni visibilidad técnica.",
    detail: "Supabase · PostgreSQL · Cloudflare",
  },
];

const workSteps = [
  { title: "Entender", text: "Relevar el proceso, sus usuarios y el problema que realmente necesita resolverse." },
  { title: "Acotar", text: "Definir una primera etapa con entregables y criterios de validación concretos." },
  { title: "Construir", text: "Desarrollar por hitos, mostrando decisiones y avances antes de ampliar el alcance." },
  { title: "Validar", text: "Probar escenarios críticos, documentar y preparar una entrega que pueda sostenerse." },
];

const assurances = [
  { label: "Datos", text: "Modelos, consultas y migraciones pensados para mantener consistencia." },
  { label: "Acceso", text: "Roles, RLS, RPCs y superficies expuestas según cada canal." },
  { label: "Calidad", text: "Pruebas funcionales y revisión de los recorridos que no pueden fallar." },
  { label: "Operación", text: "Logs, documentación y despliegues que ayudan a entender qué ocurre." },
];

const faqs = [
  {
    question: "¿Qué tipo de proyecto encaja mejor con B-Software?",
    answer:
      "Procesos internos que hoy dependen de planillas, carga repetitiva o herramientas desconectadas; también aplicaciones Flutter, portales de consulta e integraciones con bases de datos y APIs.",
  },
  {
    question: "¿Cómo se define el alcance inicial?",
    answer:
      "Se comienza por el problema más verificable. Antes de desarrollar se acuerdan objetivos, entregables y criterios de aceptación para esa primera etapa.",
  },
  {
    question: "¿El trabajo incluye seguridad y pruebas?",
    answer:
      "Sí. Roles, permisos, reglas de datos y pruebas forman parte de la arquitectura cuando el producto lo requiere; no se dejan únicamente para el final.",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://bsoftware.pages.dev/#organization",
      name: "B-Software",
      alternateName: "B Software",
      url: "https://bsoftware.pages.dev/",
      logo: {
        "@type": "ImageObject",
        url: "https://bsoftware.pages.dev/brand/logo-b.png",
        contentUrl: "https://bsoftware.pages.dev/brand/logo-b.png",
        width: 1120,
        height: 1120,
      },
      description:
        "Desarrollo de sistemas internos, aplicaciones Flutter e integraciones con foco en procesos, datos, seguridad y operación.",
      email: "gabrielboan14@gmail.com",
      telephone: "+54 9 343 406 4408",
      founder: {
        "@type": "Person",
        "@id": "https://bsoftware.pages.dev/sobre-b-software/#gabriel-boan",
        name: "Gabriel Boan",
        url: "https://bsoftware.pages.dev/sobre-b-software/",
      },
      address: {
        "@type": "PostalAddress",
        addressLocality: "Paraná",
        addressRegion: "Entre Ríos",
        addressCountry: "AR",
      },
      areaServed: ["Argentina", "Remoto"],
      sameAs: ["https://github.com/gabyboan"],
      knowsAbout: [
        "Sistemas internos",
        "Desarrollo Flutter",
        "Supabase",
        "PostgreSQL",
        "Row Level Security",
        "Cloudflare",
        "Automatización",
        "QA funcional",
      ],
      makesOffer: services.map((service) => ({
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: service.title,
          description: service.description,
        },
      })),
    },
    {
      "@type": "WebSite",
      "@id": "https://bsoftware.pages.dev/#website",
      name: "B-Software",
      alternateName: "B Software",
      url: "https://bsoftware.pages.dev/",
      inLanguage: "es-AR",
      publisher: { "@id": "https://bsoftware.pages.dev/#organization" },
    },
    {
      "@type": "FAQPage",
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: { "@type": "Answer", text: faq.answer },
      })),
    },
  ],
};
---

<Layout
  title="B-Software | Sistemas internos y aplicaciones para operación real"
  description="Desarrollo de sistemas internos, aplicaciones Flutter e integraciones con Supabase y PostgreSQL para ordenar procesos, personas y datos."
  navVariant="compact"
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main class="home-page">
    <section class="home-hero" aria-labelledby="home-title">
      <div class="hero-copy">
        <p class="eyebrow">Software a medida · Paraná y remoto</p>
        <h1 id="home-title">Sistemas internos para ordenar procesos, personas y datos.</h1>
        <p class="home-lead">
          B-Software transforma operaciones dispersas en productos claros: sistemas internos, aplicaciones Flutter e integraciones con reglas y trazabilidad.
        </p>
        <div class="home-actions">
          <a class="button primary" href="#proyectos">Ver casos de estudio</a>
          <a class="text-link" href="#contacto">Contar un proceso <span aria-hidden="true">↗</span></a>
        </div>
      </div>

      <div class="hero-system" aria-label="Proceso, datos y producto conectados">
        <div class="system-top"><span>B-Software</span><span>Arquitectura operativa</span></div>
        <div class="system-flow">
          <article><small>01</small><strong>Proceso</strong><p>Personas, reglas y tareas reales.</p></article>
          <span class="system-arrow" aria-hidden="true">→</span>
          <article><small>02</small><strong>Datos</strong><p>Una fuente consistente y controlada.</p></article>
          <span class="system-arrow" aria-hidden="true">→</span>
          <article><small>03</small><strong>Producto</strong><p>La interfaz adecuada para operar.</p></article>
        </div>
        <div class="system-bottom"><span>Flutter</span><span>Next.js</span><span>Supabase</span><span>PostgreSQL</span></div>
      </div>
    </section>

    <section id="proyectos" class="home-section case-section" aria-labelledby="cases-title">
      <div class="home-heading">
        <p class="section-index">01 / Casos de estudio</p>
        <h2 id="cases-title">La capacidad técnica se entiende mejor cuando resuelve algo concreto.</h2>
      </div>

      <div class="case-list">
        <article class="featured-case rrhh-card">
          <div class="case-copy">
            <p class="case-kicker">Caso principal · Recursos Humanos</p>
            <h3>Un ecosistema para conectar legajos, horas, suplencias y consultas.</h3>
            <p>
              Cuatro productos comparten un núcleo de datos y reglas de acceso. Cada canal resuelve un momento distinto sin duplicar identidad, permisos ni lógica operativa.
            </p>
            <dl class="case-facts">
              <div><dt>Productos</dt><dd>4 conectados</dd></div>
              <div><dt>Canales</dt><dd>Web · escritorio · portal</dd></div>
              <div><dt>Núcleo</dt><dd>Supabase · PostgreSQL</dd></div>
            </dl>
            <a class="case-link" href="/proyectos/gestion-recursos-humanos/">Explorar el caso completo <span aria-hidden="true">↗</span></a>
          </div>
          <div class="case-map" aria-hidden="true">
            <span class="map-node map-legajo">Legajo Digital</span>
            <span class="map-line line-a"></span>
            <span class="map-node map-core">Supabase<small>datos · roles · RPC</small></span>
            <span class="map-line line-b"></span>
            <span class="map-node map-app">Gestión RRHH</span>
            <span class="map-node map-portal">Consulta Horas</span>
          </div>
        </article>

        <article class="featured-case price-card">
          <div class="price-visual" aria-hidden="true">
            <span class="price-orbit orbit-one"></span><span class="price-orbit orbit-two"></span>
            <div class="price-center"><small>Dato</small><strong>Precio + lugar + evidencia</strong></div>
            <span class="price-label label-local">Local verificable</span>
            <span class="price-label label-online">Referencia online</span>
            <span class="price-label label-date">Observación fechada</span>
          </div>
          <div class="case-copy">
            <p class="case-kicker">Investigación y demostración técnica</p>
            <h3>Comparar precios sin perder el contexto de cada fuente.</h3>
            <p>
              Un producto mobile-first que combina ubicación, sucursales y niveles de certeza para no presentar una referencia online como disponibilidad local confirmada.
            </p>
            <dl class="case-facts">
              <div><dt>Interfaz</dt><dd>Flutter</dd></div>
              <div><dt>Datos</dt><dd>Supabase · RPCs</dd></div>
              <div><dt>Criterio</dt><dd>Evidencia y vigencia</dd></div>
            </dl>
            <a class="case-link" href="/proyectos/comparador-geolocalizado-de-precios/">Ver decisiones del producto <span aria-hidden="true">↗</span></a>
          </div>
        </article>
      </div>
    </section>

    <section id="servicios" class="home-section services-section" aria-labelledby="services-title">
      <div class="home-heading compact-heading">
        <p class="section-index">02 / Servicios</p>
        <h2 id="services-title">Tres formas de empezar, una misma manera de trabajar.</h2>
      </div>
      <div class="services-list">
        {services.map((service) => (
          <article>
            <span>{service.number}</span>
            <div><h3>{service.title}</h3><p>{service.description}</p></div>
            <small>{service.detail}</small>
          </article>
        ))}
      </div>
    </section>

    <section id="metodo" class="home-section method-section" aria-labelledby="method-title">
      <div class="method-intro">
        <p class="section-index">03 / Cómo trabajo</p>
        <h2 id="method-title">Primero una etapa verificable. Después, lo que tenga sentido construir.</h2>
        <p>El alcance se vuelve más claro cuando cada bloque termina en algo que puede revisarse y decidirse.</p>
      </div>
      <ol class="method-list">
        {workSteps.map((step, index) => (
          <li><span>{String(index + 1).padStart(2, "0")}</span><div><h3>{step.title}</h3><p>{step.text}</p></div></li>
        ))}
      </ol>
    </section>

    <section id="calidad" class="trust-section" aria-labelledby="trust-title">
      <div class="trust-inner">
        <div class="trust-heading">
          <p class="section-index">04 / Criterio técnico</p>
          <h2 id="trust-title">Lo importante no es solamente que funcione hoy.</h2>
          <p>Seguridad, calidad y operación forman parte del producto cuando ayudan a reducir incertidumbre.</p>
        </div>
        <div class="trust-list">
          {assurances.map((item) => (
            <article><span>{item.label}</span><p>{item.text}</p></article>
          ))}
        </div>
      </div>
    </section>

    <section class="home-section about-strip" aria-labelledby="about-title">
      <div>
        <p class="section-index">05 / Detrás de B-Software</p>
        <h2 id="about-title">Criterio técnico con una conversación directa.</h2>
      </div>
      <div>
        <p>
          B-Software es la marca profesional independiente de Gabriel Boan, desarrollador de Paraná, Entre Ríos. El foco está en entender procesos y convertirlos en software mantenible, explicable y útil para quienes lo operan.
        </p>
        <a class="text-link" href="/sobre-b-software/">Conocer el enfoque y la experiencia <span aria-hidden="true">→</span></a>
      </div>
    </section>

    <section id="faq" class="home-section faq-clean" aria-labelledby="faq-title">
      <div class="home-heading compact-heading">
        <p class="section-index">06 / Preguntas frecuentes</p>
        <h2 id="faq-title">Lo esencial antes de empezar.</h2>
      </div>
      <div class="faq-clean-list">
        {faqs.map((faq, index) => (
          <details>
            <summary><span>{String(index + 1).padStart(2, "0")}</span>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section id="contacto" class="home-contact" aria-labelledby="contact-title">
      <div>
        <p class="section-index">¿Tenés un proceso para ordenar?</p>
        <h2 id="contact-title">Conversemos sobre una primera etapa concreta.</h2>
      </div>
      <div class="contact-links">
        <a class="button primary" href="mailto:gabrielboan14@gmail.com">Escribir por email</a>
        <a class="button secondary" href="https://wa.me/5493434064408" target="_blank" rel="noreferrer">Abrir WhatsApp</a>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <a class="footer-brand" href="/" aria-label="B-Software inicio">
        <span class="footer-logo"><img src="/brand/logo-b.png" alt="" width="64" height="64" loading="lazy" /></span>
        <span><strong>B Software</strong><small>Sistemas internos, Flutter e integraciones</small></span>
      </a>
      <nav class="footer-links" aria-label="Enlaces secundarios">
        <a href="/sobre-b-software/">Sobre B-Software</a>
        <a href="/#proyectos">Casos</a>
        <a href="https://github.com/gabyboan" target="_blank" rel="noreferrer">GitHub</a>
        <a href="/#contacto">Contacto</a>
      </nav>
    </div>
  </footer>
</Layout>

<style>
  .home-page { background: #f5f4f0; color: #171815; }
  .home-hero, .home-section, .home-contact { max-width: 1180px; margin: 0 auto; padding-inline: 20px; }
  .home-hero { min-height: 690px; padding-top: 88px; padding-bottom: 78px; display: grid; grid-template-columns: 1.08fr .92fr; gap: 70px; align-items: center; }
  .home-hero h1 { max-width: 780px; font-size: clamp(3.5rem, 6.4vw, 6.8rem); line-height: .92; letter-spacing: -.06em; }
  .home-lead { max-width: 700px; margin-top: 28px; color: #666963; font-size: 1.18rem; line-height: 1.75; }
  .home-actions { margin-top: 34px; display: flex; flex-wrap: wrap; align-items: center; gap: 22px; }
  .text-link, .case-link { display: inline-flex; align-items: center; gap: 8px; color: #263fbd; font-weight: 900; }
  .text-link:hover, .case-link:hover { text-decoration: underline; text-underline-offset: 5px; }
  .hero-system { min-height: 460px; display: flex; flex-direction: column; justify-content: space-between; border: 1px solid #ceccc5; border-radius: 10px; padding: 22px; background: #fbfaf7; box-shadow: 0 24px 60px rgb(23 24 21 / .08); }
  .system-top, .system-bottom { display: flex; justify-content: space-between; gap: 12px; color: #777771; font-size: .7rem; font-weight: 850; letter-spacing: .08em; text-transform: uppercase; }
  .system-flow { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 8px; align-items: center; }
  .system-flow article { min-width: 0; border-top: 2px solid #263fbd; padding-top: 12px; }
  .system-flow small { color: #263fbd; font-weight: 900; }
  .system-flow strong, .system-flow p { display: block; }
  .system-flow strong { margin-top: 18px; font-size: 1.05rem; }
  .system-flow p { margin-top: 8px; color: #777771; font-size: .76rem; line-height: 1.5; }
  .system-arrow { color: #989a94; }
  .system-bottom { justify-content: flex-start; flex-wrap: wrap; }
  .system-bottom span { border: 1px solid #d6d4cd; border-radius: 999px; padding: 6px 8px; background: #fff; }

  .home-section { padding-top: 104px; padding-bottom: 104px; }
  .home-heading { display: grid; grid-template-columns: .32fr .68fr; gap: 48px; align-items: start; }
  .home-heading h2, .method-intro h2, .trust-heading h2, .about-strip h2, .home-contact h2 { margin-top: 0; font-size: clamp(2.3rem, 4.6vw, 4.5rem); letter-spacing: -.04em; }
  .section-index { color: #263fbd; font-size: .74rem; font-weight: 950; letter-spacing: .11em; text-transform: uppercase; }
  .case-list { margin-top: 54px; display: grid; gap: 22px; }
  .featured-case { min-height: 570px; display: grid; grid-template-columns: 1.02fr .98fr; overflow: hidden; border-radius: 10px; }
  .rrhh-card { color: #f5f4f0; background: #111214; }
  .case-copy { display: flex; flex-direction: column; padding: 42px; }
  .case-kicker { color: #a89bf7; font-size: .72rem; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; }
  .featured-case h3 { margin-top: 22px; max-width: 680px; font-size: clamp(2rem, 4vw, 3.8rem); letter-spacing: -.04em; line-height: 1; }
  .case-copy > p:not(.case-kicker) { margin-top: 24px; max-width: 660px; color: rgb(255 255 255 / .66); line-height: 1.75; }
  .case-facts { margin: 34px 0 0; display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid rgb(255 255 255 / .17); }
  .case-facts div { padding: 16px 12px 0 0; }
  .case-facts dt { color: rgb(255 255 255 / .46); font-size: .66rem; font-weight: 850; text-transform: uppercase; }
  .case-facts dd { margin: 6px 0 0; font-size: .82rem; font-weight: 800; }
  .case-link { margin-top: auto; padding-top: 30px; color: #d1ccff; }
  .case-map { position: relative; margin: 22px 22px 22px 0; overflow: hidden; border: 1px solid rgb(255 255 255 / .1); border-radius: 8px; background-color: #15171b; background-image: radial-gradient(rgb(255 255 255 / .08) 1px, transparent 1px); background-size: 22px 22px; }
  .map-node { position: absolute; z-index: 2; min-width: 130px; border: 1px solid rgb(168 155 247 / .45); border-radius: 7px; padding: 13px; background: #1b1d23; color: #f5f4f0; font-size: .75rem; font-weight: 850; }
  .map-node small { display: block; margin-top: 6px; color: #888d98; font-size: .6rem; font-weight: 600; }
  .map-legajo { top: 16%; left: 8%; }.map-core { top: 42%; left: 37%; border-color: #a89bf7; }.map-app { right: 8%; top: 18%; }.map-portal { right: 8%; bottom: 15%; border-color: #f0b36c; }
  .map-line { position: absolute; z-index: 1; height: 1px; background: #a89bf7; transform-origin: left center; }
  .line-a { top: 29%; left: 28%; width: 31%; transform: rotate(28deg); }.line-b { top: 53%; left: 55%; width: 31%; transform: rotate(-28deg); }
  .price-card { border: 1px solid #d2d1cb; background: #fff; }
  .price-card .case-kicker { color: #147843; }
  .price-card .case-copy > p:not(.case-kicker) { color: #666963; }
  .price-card .case-facts { border-color: #d8d7d1; }
  .price-card .case-facts dt { color: #777771; }.price-card .case-facts dd { color: #252622; }
  .price-card .case-link { color: #147843; }
  .price-visual { position: relative; min-height: 480px; margin: 22px 0 22px 22px; overflow: hidden; border-radius: 8px; background: #eef5ef; }
  .price-center { position: absolute; top: 50%; left: 50%; z-index: 2; width: 190px; border: 1px solid #abcbb5; border-radius: 50%; padding: 48px 24px; background: #fff; text-align: center; transform: translate(-50%, -50%); }
  .price-center small, .price-center strong { display: block; }.price-center small { color: #147843; font-weight: 900; text-transform: uppercase; }.price-center strong { margin-top: 8px; }
  .price-orbit { position: absolute; top: 50%; left: 50%; border: 1px solid #b9d4c1; border-radius: 50%; transform: translate(-50%, -50%); }.orbit-one { width: 330px; height: 330px; }.orbit-two { width: 460px; height: 460px; border-style: dashed; }
  .price-label { position: absolute; border: 1px solid #c6daca; border-radius: 999px; padding: 8px 10px; color: #285c3b; background: rgb(255 255 255 / .9); font-size: .7rem; font-weight: 850; }.label-local { top: 13%; left: 12%; }.label-online { right: 8%; top: 34%; }.label-date { bottom: 12%; left: 18%; }

  .compact-heading { grid-template-columns: .35fr .65fr; }
  .services-list { margin-top: 52px; border-top: 1px solid #c9c7c0; }
  .services-list article { display: grid; grid-template-columns: 60px 1fr .5fr; gap: 28px; align-items: start; border-bottom: 1px solid #c9c7c0; padding: 30px 0; }
  .services-list > article > span { color: #263fbd; font-size: .75rem; font-weight: 900; }
  .services-list h3 { font-size: 1.45rem; }.services-list p { margin-top: 9px; max-width: 680px; color: #666963; line-height: 1.7; }
  .services-list small { color: #777771; text-align: right; }

  .method-section { display: grid; grid-template-columns: .85fr 1.15fr; gap: 86px; border-top: 1px solid #d2d1cb; }
  .method-intro > p:last-child { margin-top: 24px; max-width: 520px; color: #666963; line-height: 1.75; }
  .method-list { margin: 0; padding: 0; list-style: none; }
  .method-list li { display: grid; grid-template-columns: 48px 1fr; gap: 20px; border-top: 1px solid #c9c7c0; padding: 24px 0; }.method-list li:last-child { border-bottom: 1px solid #c9c7c0; }
  .method-list li > span { color: #263fbd; font-size: .74rem; font-weight: 900; }.method-list h3 { font-size: 1.25rem; }.method-list p { margin-top: 8px; color: #666963; line-height: 1.65; }

  .trust-section { color: #f5f4f0; background: #111214; }
  .trust-inner { max-width: 1180px; margin: 0 auto; padding: 100px 20px; display: grid; grid-template-columns: .9fr 1.1fr; gap: 90px; }
  .trust-heading .section-index { color: #a89bf7; }.trust-heading > p:last-child { margin-top: 24px; color: rgb(255 255 255 / .62); line-height: 1.75; }
  .trust-list { display: grid; grid-template-columns: 1fr 1fr; border-top: 1px solid rgb(255 255 255 / .18); }
  .trust-list article { min-height: 170px; border-bottom: 1px solid rgb(255 255 255 / .18); padding: 22px; }.trust-list article:nth-child(odd) { border-right: 1px solid rgb(255 255 255 / .18); }
  .trust-list span { color: #a89bf7; font-size: .7rem; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; }.trust-list p { margin-top: 20px; color: rgb(255 255 255 / .74); line-height: 1.65; }

  .about-strip { display: grid; grid-template-columns: .9fr 1.1fr; gap: 90px; border-bottom: 1px solid #d2d1cb; }
