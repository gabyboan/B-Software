---
import Layout from "../../layouts/Layout.astro";

const title = "Gestión de Recursos Humanos | Caso de estudio B-Software";
const description =
  "Caso de estudio del ecosistema de Recursos Humanos de B-Software: aplicaciones operativas, portal de consulta y un núcleo Supabase con permisos y trazabilidad.";
const canonical = "https://bsoftware.pages.dev/proyectos/gestion-recursos-humanos/";

const systems = [
  {
    index: "01",
    title: "Legajo Digital",
    kind: "Sistema interno",
    description:
      "Centraliza situación de revista, carrera, asistencia y banco inicial de horas con acceso por roles.",
    stack: "Next.js · React · TypeScript · Supabase",
    href: "https://github.com/gabyboan/legajo-digital",
  },
  {
    index: "02",
    title: "HESM Gestión RRHH",
    kind: "Operación de escritorio",
    description:
      "Ordena la carga cotidiana de horas, francos y novedades, además de consultas y exportaciones.",
    stack: "Flutter · Dart · Riverpod · Supabase",
    href: "https://github.com/gabyboan/hesm-gestion-rrhh",
  },
  {
    index: "03",
    title: "Consulta Horas",
    kind: "Portal del agente",
    description:
      "Separa la consulta pública del backoffice y expone únicamente la información necesaria de cada agente.",
    stack: "Cloudflare Pages · Workers · Turnstile",
    href: "https://github.com/gabyboan/consulta-horas",
  },
  {
    index: "04",
    title: "Suplencias Propuesta",
    kind: "Aplicación operativa",
    description:
      "Registra propuestas y coberturas con autenticación, permisos, validación de períodos y control de duplicados.",
    stack: "Flutter · Dart · PostgreSQL · Supabase",
    href: "https://github.com/gabyboan/app-suplencias-propuesta",
  },
];

const caseStudyStructuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: "Ecosistema de Gestión de Recursos Humanos",
  headline: "Un solo núcleo para los flujos de Recursos Humanos",
  description,
  url: canonical,
  inLanguage: "es-AR",
  creator: {
    "@type": "Organization",
    name: "B-Software",
    url: "https://bsoftware.pages.dev/",
  },
  about: [
    "Gestión de Recursos Humanos",
    "Sistemas internos",
    "Flutter",
    "Supabase",
    "PostgreSQL",
    "Row Level Security",
    "Cloudflare Workers",
  ],
};
---

<Layout {title} {description} {canonical} ogType="article" bodyClass="rrhh-page">
  <script type="application/ld+json" set:html={JSON.stringify(caseStudyStructuredData)} />

  <main class="rrhh-case">
    <article>
      <header class="rrhh-hero">
        <a class="back-link" href="/#proyectos">← Volver a proyectos</a>
        <div class="rrhh-heading">
          <div>
            <p class="eyebrow">Caso de estudio · Gestión RRHH</p>
            <h1>Un solo núcleo para los flujos de Recursos Humanos.</h1>
          </div>
          <p class="rrhh-lead">
            Las entradas operativas se normalizan en una misma arquitectura. Las aplicaciones consumen funciones y vistas controladas, no datos dispersos.
          </p>
        </div>
        <dl class="rrhh-facts" aria-label="Resumen del proyecto">
          <div><dt>Dominio</dt><dd>Recursos Humanos</dd></div>
          <div><dt>Productos</dt><dd>Web · escritorio · portal</dd></div>
          <div><dt>Núcleo</dt><dd>Supabase · PostgreSQL</dd></div>
          <div><dt>Controles</dt><dd>Roles · RLS · RPCs</dd></div>
        </dl>
      </header>

      <section class="flow-section" aria-labelledby="flow-title">
        <div class="flow-intro">
          <div>
            <p class="flow-label">Arquitectura operativa</p>
            <h2 id="flow-title">Ecosistema de gestión de Recursos Humanos</h2>
          </div>
          <p>Cada tarjeta representa una aplicación o un módulo conectado al núcleo de datos.</p>
        </div>

        <div class="rrhh-diagram">
          <div class="diagram-toolbar">
            <div class="diagram-legend" aria-label="Leyenda de conexiones">
              <span class="diagram-legend-item"><i class="diagram-legend-line sync" aria-hidden="true"></i> consulta y actualización</span>
              <span class="diagram-legend-item"><i class="diagram-legend-line read" aria-hidden="true"></i> consulta de solo lectura</span>
              <span class="diagram-legend-item"><i class="diagram-legend-line module" aria-hidden="true"></i> módulo dependiente</span>
            </div>
            <button class="diagram-reset" id="resetLayout" type="button">Restablecer disposición</button>
          </div>

          <section class="diagram-viewport" aria-label="Diagrama interactivo de aplicaciones RRHH">
            <div id="workspace" class="diagram-workspace">
              <svg class="diagram-edges" aria-hidden="true">
                <defs>
                  <marker id="arrow-sync" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto-start-reverse"><path d="M0,0 L8,4 L0,8 z" fill="#a89bf7"></path></marker>
                  <marker id="arrow-read" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto"><path d="M0,0 L8,4 L0,8 z" fill="#f0b36c"></path></marker>
                </defs>
                <g id="edgeLayer"></g><g id="labelLayer"></g>
              </svg>

              <article class="diagram-node" data-node="legajo" tabindex="0" style="left:72px; top:58px" aria-label="Legajo Digital. Aplicación web.">
                <header class="diagram-node-header"><span class="diagram-badge"></span><span class="diagram-node-title">Legajo Digital</span><span class="diagram-node-kind">web</span></header>
                <ul class="diagram-fields"><li>personas</li><li>datos personales</li><li>datos laborales</li><li>banco de horas inicial</li></ul>
              </article>

              <article class="diagram-node core" data-node="supabase" tabindex="0" style="left:475px; top:245px" aria-label="Supabase HESM. Núcleo de datos.">
                <header class="diagram-node-header"><span class="diagram-badge"></span><span class="diagram-node-title">Supabase · HESM</span><span class="diagram-node-kind">core</span></header>
                <ul class="diagram-fields"><li>Postgres</li><li>Auth y roles</li><li>RLS y RPC</li><li>migraciones</li></ul>
                <p class="diagram-core-note">Núcleo compartido de datos y reglas de acceso.</p>
              </article>

              <article class="diagram-node" data-node="suplencias" tabindex="0" style="left:922px; top:82px" aria-label="App Suplencias. Aplicación Android.">
                <header class="diagram-node-header"><span class="diagram-badge"></span><span class="diagram-node-title">App Suplencias</span><span class="diagram-node-kind">apk</span></header>
                <ul class="diagram-fields"><li>suplencias</li><li>personas suplentes</li><li>vistas por jefatura</li></ul>
              </article>

              <article class="diagram-node" data-node="gestion" tabindex="0" style="left:58px; top:386px" aria-label="Gestión RRHH. Aplicación Windows.">
                <header class="diagram-node-header"><span class="diagram-badge"></span><span class="diagram-node-title">Gestión RRHH</span><span class="diagram-node-kind">windows</span></header>
                <ul class="diagram-fields"><li>novedades administrativas</li><li>horas y permisos</li><li>consulta y exportación</li></ul>
              </article>

              <article class="diagram-node read-node" data-node="consulta" tabindex="0" style="left:905px; top:470px" aria-label="Consulta de Horas. Portal de lectura.">
                <header class="diagram-node-header"><span class="diagram-badge"></span><span class="diagram-node-title">Consulta de Horas</span><span class="diagram-node-kind">portal</span></header>
                <ul class="diagram-fields"><li>consulta individual</li><li>acceso acotado por RPC</li><li>sin escritura directa</li></ul>
              </article>

              <article class="diagram-node module-node" data-node="licencias" tabindex="0" style="left:58px; top:655px" aria-label="Módulo de licencias médicas.">
                <header class="diagram-node-header"><span class="diagram-badge"></span><span class="diagram-node-title">Licencias médicas</span><span class="diagram-node-kind">módulo</span></header>
              </article>
              <article class="diagram-node module-node" data-node="imprevistos" tabindex="0" style="left:270px; top:655px" aria-label="Módulo artículo 8, imprevistos.">
                <header class="diagram-node-header"><span class="diagram-badge"></span><span class="diagram-node-title">Artículo 8 · imprevistos</span><span class="diagram-node-kind">módulo</span></header>
              </article>
              <article class="diagram-node module-node" data-node="compensatorias" tabindex="0" style="left:58px; top:728px" aria-label="Módulo horas compensatorias.">
                <header class="diagram-node-header"><span class="diagram-badge"></span><span class="diagram-node-title">Horas compensatorias</span><span class="diagram-node-kind">módulo</span></header>
              </article>
              <article class="diagram-node module-node" data-node="permisos" tabindex="0" style="left:270px; top:728px" aria-label="Módulo permisos de salida.">
                <header class="diagram-node-header"><span class="diagram-badge"></span><span class="diagram-node-title">Permisos de salida</span><span class="diagram-node-kind">módulo</span></header>
              </article>
              <article class="diagram-node module-node" data-node="capacitacion" tabindex="0" style="left:164px; top:801px" aria-label="Módulo capacitación.">
                <header class="diagram-node-header"><span class="diagram-badge"></span><span class="diagram-node-title">Capacitación</span><span class="diagram-node-kind">módulo</span></header>
              </article>
            </div>
          </section>
          <p class="diagram-tip"><strong>Interacción:</strong> arrastrá nodos para reorganizar el mapa. Al pasar el cursor sobre una aplicación o módulo, se resaltan únicamente sus conexiones.</p>
        </div>
      </section>

      <section class="rrhh-summary">
        <div>
          <p class="section-number">01 / El problema</p>
          <h2>El dato pierde valor cuando cada proceso trabaja por separado</h2>
        </div>
        <div class="summary-copy">
          <p>
            Asistencia, licencias, horas y suplencias afectan a la misma persona, pero suelen vivir en planillas, mensajes o aplicaciones aisladas. Eso multiplica la carga manual y vuelve difícil explicar de dónde salió un saldo o quién modificó un registro.
          </p>
          <p>
            El objetivo no fue sumar otra pantalla: fue ordenar el recorrido completo de la información y mantener una referencia consistente entre los distintos productos.
          </p>
        </div>
      </section>

      <section class="principles-section">
        <div class="principles-heading">
          <p class="section-number">02 / Decisiones</p>
          <h2>La arquitectura sigue al proceso real</h2>
        </div>
        <div class="principles-list">
          <article><span>01</span><div><h3>Un núcleo compartido</h3><p>Los productos parten de entidades, validaciones y reglas comunes para evitar versiones contradictorias del mismo dato.</p></div></article>
          <article><span>02</span><div><h3>Acceso mínimo por canal</h3><p>El backoffice, las aplicaciones operativas y el portal público no exponen la misma superficie ni los mismos permisos.</p></div></article>
          <article><span>03</span><div><h3>Reglas cerca de los datos</h3><p>RLS, funciones y validaciones en PostgreSQL sostienen los límites aunque cambie la interfaz que consume la información.</p></div></article>
          <article><span>04</span><div><h3>Trazabilidad operativa</h3><p>Estados, períodos e identidad permiten reconstruir qué ocurrió sin depender de conversaciones o archivos dispersos.</p></div></article>
        </div>
      </section>

      <section class="systems-section" aria-labelledby="systems-title">
        <div class="systems-heading">
          <p class="section-number">03 / Productos</p>
          <h2 id="systems-title">Cuatro productos, un mismo dominio</h2>
          <p>El mapa resume cómo se relacionan. Cada implementación resuelve un momento distinto de la operación.</p>
        </div>
        <div class="systems-list">
          {systems.map((system) => (
            <article class="system-row">
              <span>{system.index}</span>
              <div><p>{system.kind}</p><h3>{system.title}</h3></div>
              <p>{system.description}</p>
              <div class="system-tech"><small>{system.stack}</small><a href={system.href} target="_blank" rel="noreferrer">Ver repositorio ↗</a></div>
            </article>
          ))}
        </div>
      </section>

      <section class="rrhh-outcome">
        <p class="section-number">Resultado</p>
        <blockquote>Una arquitectura capaz de sumar nuevas interfaces sin volver a inventar identidad, permisos y reglas para cada una.</blockquote>
        <div class="outcome-tags" aria-label="Tecnologías principales">
          <span>Flutter</span><span>Next.js</span><span>Supabase</span><span>PostgreSQL</span><span>RLS</span><span>Cloudflare</span>
        </div>
      </section>

      <section class="rrhh-cta">
        <div><p class="eyebrow">¿Tenés un proceso disperso?</p><h2>Podemos convertirlo en una primera etapa verificable.</h2></div>
        <a class="button primary" href="/#contacto">Conversemos</a>
      </section>
    </article>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <a class="footer-brand" href="/" aria-label="B-Software inicio">
        <span class="footer-logo"><img src="/brand/logo-b.png" alt="" width="64" height="64" loading="lazy" /></span>
        <span><strong>B Software</strong><small>Sistemas internos, Flutter e integraciones</small></span>
      </a>
      <nav class="footer-links" aria-label="Enlaces secundarios">
        <a href="/#servicios">Servicios</a><a href="/#proyectos">Proyectos</a><a href="/#contacto">Contacto</a>
      </nav>
    </div>
  </footer>

  <script>
    const workspace = document.querySelector<HTMLElement>("#workspace");
    const edgeLayer = document.querySelector<SVGGElement>("#edgeLayer");
    const labelLayer = document.querySelector<SVGGElement>("#labelLayer");
    const resetButton = document.querySelector<HTMLButtonElement>("#resetLayout");

    if (workspace && edgeLayer && labelLayer && resetButton) {
      const nodes = Object.fromEntries(
        [...workspace.querySelectorAll<HTMLElement>("[data-node]")].map((node) => [node.dataset.node ?? "", node]),
      );
      const originalPositions = Object.fromEntries(
        Object.entries(nodes).map(([id, node]) => [id, { left: parseFloat(node.style.left), top: parseFloat(node.style.top) }]),
      );
      const edges = [
        { id: "legajo-sync", source: "legajo", target: "supabase", type: "sync", label: "altas · actualización" },
        { id: "gestion-sync", source: "gestion", target: "supabase", type: "sync", label: "registra · consulta" },
        { id: "suplencias-sync", source: "suplencias", target: "supabase", type: "sync", label: "registra · consulta" },
        { id: "consulta-read", source: "consulta", target: "supabase", type: "read", label: "consulta RPC" },
        { id: "gestion-licencias", source: "gestion", target: "licencias", type: "module" },
        { id: "gestion-imprevistos", source: "gestion", target: "imprevistos", type: "module", label: "módulos" },
        { id: "gestion-compensatorias", source: "gestion", target: "compensatorias", type: "module" },
        { id: "gestion-permisos", source: "gestion", target: "permisos", type: "module" },
        { id: "gestion-capacitacion", source: "gestion", target: "capacitacion", type: "module" },
      ];
      const ns = "http://www.w3.org/2000/svg";
      const createSvg = (name: string, attrs: Record<string, string | number> = {}) => {
        const element = document.createElementNS(ns, name);
        Object.entries(attrs).forEach(([key, value]) => element.setAttribute(key, String(value)));
        return element;
      };
      const geometry = (node: HTMLElement) => {
        const left = parseFloat(node.style.left) || 0;
        const top = parseFloat(node.style.top) || 0;
        return { left, top, width: node.offsetWidth, height: node.offsetHeight, cx: left + node.offsetWidth / 2, cy: top + node.offsetHeight / 2 };
      };
      const anchorBetween = (sourceNode: HTMLElement, targetNode: HTMLElement) => {
        const a = geometry(sourceNode);
        const b = geometry(targetNode);
        const dx = b.cx - a.cx;
        const dy = b.cy - a.cy;
        if (Math.abs(dx) >= Math.abs(dy)) return dx >= 0 ? { x: a.left + a.width, y: a.cy, side: "right" } : { x: a.left, y: a.cy, side: "left" };
        return dy >= 0 ? { x: a.cx, y: a.top + a.height, side: "bottom" } : { x: a.cx, y: a.top, side: "top" };
      };
      const pathFor = (from: { x: number; y: number; side: string }, to: { x: number; y: number; side: string }) => {
        const horizontal = ["left", "right"].includes(from.side) && ["left", "right"].includes(to.side);
        if (horizontal) {
          const midX = Math.round((from.x + to.x) / 2);
          return { d: `M ${from.x} ${from.y} H ${midX} V ${to.y} H ${to.x}`, labelX: midX, labelY: Math.round((from.y + to.y) / 2) - 8 };
        }
        const midY = Math.round((from.y + to.y) / 2);
        return { d: `M ${from.x} ${from.y} V ${midY} H ${to.x} V ${to.y}`, labelX: Math.round((from.x + to.x) / 2), labelY: midY - 8 };
      };
      const renderEdges = () => {
        edgeLayer.replaceChildren();
        labelLayer.replaceChildren();
        edges.forEach((edge) => {
          const from = anchorBetween(nodes[edge.source], nodes[edge.target]);
          const to = anchorBetween(nodes[edge.target], nodes[edge.source]);
          const route = pathFor(from, to);
          const path = createSvg("path", { d: route.d, class: `diagram-edge ${edge.type}`, "data-edge": edge.id });
          if (edge.type === "sync") { path.setAttribute("marker-start", "url(#arrow-sync)"); path.setAttribute("marker-end", "url(#arrow-sync)"); }
          if (edge.type === "read") path.setAttribute("marker-end", "url(#arrow-read)");
          edgeLayer.append(path);
          if (edge.label) {
            const label = createSvg("text", { x: route.labelX, y: route.labelY, class: `diagram-edge-label ${edge.type}`, "text-anchor": "middle" });
            label.textContent = edge.label;
            labelLayer.append(label);
          }
        });
      };
      const edgeIdsFor = (nodeId: string) => edges.filter((edge) => edge.source === nodeId || edge.target === nodeId).map((edge) => edge.id);
      const setFocus = (nodeId: string) => {
        const ids = edgeIdsFor(nodeId);
        workspace.classList.add("has-focus");
        workspace.querySelectorAll<SVGPathElement>(".diagram-edge").forEach((edge) => edge.classList.toggle("is-highlighted", ids.includes(edge.dataset.edge ?? "")));
        Object.entries(nodes).forEach(([id, node]) => node.classList.toggle("is-focused", id === nodeId));
      };
      const clearFocus = () => {
        workspace.classList.remove("has-focus");
        workspace.querySelectorAll(".diagram-edge").forEach((edge) => edge.classList.remove("is-highlighted"));
        Object.values(nodes).forEach((node) => node.classList.remove("is-focused"));
      };
      let drag: { node: HTMLElement; offsetX: number; offsetY: number } | null = null;
      let zIndex = 5;
      const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

      Object.values(nodes).forEach((node) => {
        node.addEventListener("pointerdown", (event) => {
          if (event.button !== 0) return;
          event.preventDefault();
          const rect = workspace.getBoundingClientRect();
          drag = { node, offsetX: event.clientX - rect.left - (parseFloat(node.style.left) || 0), offsetY: event.clientY - rect.top - (parseFloat(node.style.top) || 0) };
          node.setPointerCapture(event.pointerId);
          node.classList.add("is-dragging");
          node.style.zIndex = String(++zIndex);
          setFocus(node.dataset.node ?? "");
        });
        node.addEventListener("pointermove", (event) => {
          if (!drag || drag.node !== node) return;
          const rect = workspace.getBoundingClientRect();
          node.style.left = `${Math.round(clamp(event.clientX - rect.left - drag.offsetX, 14, workspace.clientWidth - node.offsetWidth - 14))}px`;
          node.style.top = `${Math.round(clamp(event.clientY - rect.top - drag.offsetY, 14, workspace.clientHeight - node.offsetHeight - 14))}px`;
          renderEdges();
        });
        const endDrag = (event: PointerEvent) => {
          if (!drag || drag.node !== node) return;
          node.classList.remove("is-dragging");
          try { node.releasePointerCapture(event.pointerId); } catch {}
          drag = null;
        };
        node.addEventListener("pointerup", endDrag);
        node.addEventListener("pointercancel", endDrag);
        node.addEventListener("mouseenter", () => { if (!drag) setFocus(node.dataset.node ?? ""); });
        node.addEventListener("mouseleave", () => { if (!drag) clearFocus(); });
        node.addEventListener("focus", () => setFocus(node.dataset.node ?? ""));
        node.addEventListener("blur", clearFocus);
      });
      resetButton.addEventListener("click", () => {
        Object.entries(nodes).forEach(([id, node]) => {
          node.style.left = `${originalPositions[id].left}px`;
          node.style.top = `${originalPositions[id].top}px`;
          node.style.zIndex = "2";
        });
        zIndex = 5;
        clearFocus();
        renderEdges();
      });
      window.addEventListener("resize", renderEdges);
      renderEdges();
    }
  </script>
</Layout>

<style>
  :global(body.rrhh-page) { background: #111214; color: #f4f4f6; }
  :global(body.rrhh-page .site-header) { border-color: rgb(255 255 255 / .1); background: rgb(17 18 20 / .92); }
  :global(body.rrhh-page .brand strong), :global(body.rrhh-page .nav-links a), :global(body.rrhh-page .nav-cta), :global(body.rrhh-page .mobile-nav summary) { color: #f4f4f6; }
  :global(body.rrhh-page .brand small) { color: #9da1ad; }
  :global(body.rrhh-page .brand-mark) { border-color: rgb(255 255 255 / .15); }
  :global(body.rrhh-page .nav-links a:hover), :global(body.rrhh-page .nav-cta:hover), :global(body.rrhh-page .mobile-nav[open] summary) { background: #202229; }
  :global(body.rrhh-page .nav-cta), :global(body.rrhh-page .mobile-nav summary) { border-color: rgb(255 255 255 / .18); }
  :global(body.rrhh-page .mobile-nav nav) { border-color: rgb(255 255 255 / .14); background: #191b20; }
  :global(body.rrhh-page .mobile-nav nav a) { color: #f4f4f6; }
  :global(body.rrhh-page .mobile-nav nav a:hover) { background: #252832; }
  .rrhh-case { --signal: #a89bf7; --signal-soft: rgb(168 155 247 / .15); background: #111214; color: #f4f4f6; }
  .rrhh-case .back-link { color: #9da1ad; }
  .rrhh-case .eyebrow { border-color: rgb(168 155 247 / .32); color: #d1ccff; background: rgb(168 155 247 / .1); }
  .rrhh-hero { max-width: 1180px; margin: 0 auto; padding: 64px 20px 56px; }
  .rrhh-heading { display: grid; grid-template-columns: 1.35fr .65fr; gap: 64px; align-items: end; }
  .rrhh-heading h1 { max-width: 880px; font-size: clamp(3.2rem, 7.2vw, 7.2rem); line-height: .92; letter-spacing: -.055em; }
  .rrhh-lead { padding-bottom: 8px; color: #9da1ad; font-size: 1.08rem; line-height: 1.75; }
  .rrhh-facts { margin: 58px 0 0; display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid rgb(255 255 255 / .16); border-bottom: 1px solid rgb(255 255 255 / .16); }
