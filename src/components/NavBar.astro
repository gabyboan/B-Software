---
const defaultItems = [
  { href: "/#servicios", label: "Servicios" },
  { href: "/#proyectos", label: "Proyectos" },
  { href: "/#metodo", label: "Cómo trabajo" },
  { href: "/#calidad", label: "Calidad" },
  { href: "/#faq", label: "FAQ" },
  { href: "/#contacto", label: "Contacto" },
];

const compactItems = [
  { href: "/#proyectos", label: "Casos" },
  { href: "/#servicios", label: "Servicios" },
  { href: "/#metodo", label: "Proceso" },
  { href: "/sobre-b-software/", label: "Sobre" },
];

const { variant = "default" } = Astro.props;
const compact = variant === "compact";
const items = compact ? compactItems : defaultItems;
const cta = compact
  ? { href: "/#contacto", label: "Conversemos", external: false }
  : { href: "https://wa.me/5493434064408", label: "WhatsApp", external: true };
---

<header class="site-header">
  <div class="nav-shell">
    <a href="/" class="brand" aria-label="B-Software inicio">
      <span class="brand-mark">
        <img src="/brand/logo-b.png" alt="" width="42" height="42" />
      </span>
      <span>
        <strong>B-Software</strong>
        <small>Soluciones digitales</small>
      </span>
    </a>

    <nav class="nav-links" aria-label="Principal">
      {items.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <a class="nav-cta" href={cta.href} target={cta.external ? "_blank" : undefined} rel={cta.external ? "noreferrer" : undefined}>{cta.label}</a>

    <details class="mobile-nav">
      <summary aria-label="Abrir menú de navegación">Menú</summary>
      <nav aria-label="Principal móvil">
        {items.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
        <a href={cta.href} target={cta.external ? "_blank" : undefined} rel={cta.external ? "noreferrer" : undefined}>{cta.label}</a>
      </nav>
    </details>
  </div>
</header>
