    <a href="/" class="brand" aria-label="B-Software inicio">
      <span class="brand-mark">
        <img src="/brand/logo-b.png" alt="" width="42" height="42" />
      </span>
      <span>
        <strong>B-Software</strong>
        <small>Soluciones digitales</small>
      </span>
    </a>

    <nav class="nav-links" aria-label="Principal">
      {items.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <a class="nav-cta" href="https://wa.me/5493434064408" target="_blank" rel="noreferrer">WhatsApp</a>
  </div>
</header>
