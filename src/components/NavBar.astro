---
const items = [
  { href: "#calidad", label: "Calidad" },
  { href: "#proyectos", label: "Proyectos" },
  { href: "#automatizaciones", label: "Automatizaciones" },
  { href: "#github", label: "GitHub" },
  { href: "#faq", label: "FAQ" },
  { href: "#servicios", label: "Servicios" },
  { href: "#contacto", label: "Contacto" },
